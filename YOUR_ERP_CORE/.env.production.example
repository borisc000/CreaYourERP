# YOUR ERP - Production environment example
# Copy to .env on the production host and replace every placeholder.

ENVIRONMENT=production
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# Database
DATABASE_TYPE=postgresql
DATABASE_HOST=postgres.internal
DATABASE_PORT=5432
DATABASE_NAME=your_erp_prod
DATABASE_USER=your_erp_app
DATABASE_PASSWORD=replace-with-a-strong-database-password

# Security
SECRET_KEY=replace-with-at-least-32-random-characters
ALLOWED_ORIGINS=https://erp.example.com
ENABLE_DEMO_SEED=False
ENABLE_DEMO_LOGIN=False
ENABLE_DEBUG_ENDPOINTS=False
EXPOSE_DEV_PASSWORD_RESET_TOKENS=False

# Email
EMAIL_BACKEND=smtp
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=replace-with-smtp-secret
SMTP_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@example.com

# Modules enabled for v1 launch
MODULES_TO_LOAD=base,signature,document_center,crm,gantt,quotes,billing,expenses,planning,reports,hr,job_profiles,recruitment,tasks,safety,safety_activities,safety_procedures,inventory,suppliers,rentals,mail,accreditation

# Monitoring and async infrastructure
SENTRY_DSN=https://replace-with-sentry-dsn
REDIS_URL=redis://redis.internal:6379/0

# External integrations
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
AI_PROVIDER_API_KEY=
