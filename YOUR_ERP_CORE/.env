# YOUR ERP - Archivo de configuración de entorno
# ================================================
# Copiar a .env y ajustar valores según sea necesario

# AMBIENTE DE EJECUCIÓN
# Valores: development, testing, production
ENVIRONMENT=development

# SERVIDOR
HOST=0.0.0.0
PORT=8000

# BASE DE DATOS
# Tipo: postgresql, mysql, sqlite
# Para desarrollo usar sqlite, para producción usar postgresql
DATABASE_TYPE=sqlite
DATABASE_NAME=./erp_dev.db
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME_PG=your_erp_dev
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

# SEGURIDAD
# IMPORTANTE: Cambiar en producción!
SECRET_KEY=dev-secret-key-change-this-in-production

# EMAIL (SMTP)
EMAIL_BACKEND=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=your-app-password
SMTP_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@yourerp.com

# LOGGING
LOG_LEVEL=DEBUG

# MÓDULOS A CARGAR
# Separados por comas
MODULES_TO_LOAD=base,signature,document_center,crm,quotes,billing,reports,hr,attendance,payroll,recruitment,safety,inventory,riohs

# MONITOREO (SENTRY)
SENTRY_DSN=

# REDIS (Caché y colas)
REDIS_URL=redis://localhost:6379/0

# CORS - ORÍGENES PERMITIDOS (producción)
ALLOWED_ORIGINS=http://localhost:3000,https://example.com
