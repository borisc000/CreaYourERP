# ==========================================
# Firebase Admin SDK (ya configurado por Firebase CLI en deploy)
# En local/emulador no se necesita — se usa applicationDefault()
# ==========================================

# ==========================================
# Stripe (Opcional — solo para cobros/planes)
# ==========================================
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ==========================================
# Email / SMTP (Opcional — solo para envío real de emails)
# ==========================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tu-email@gmail.com
# SMTP_PASS=tu-app-password

# ==========================================
# Twilio / SMS (Opcional — solo para notificaciones SMS)
# ==========================================
# TWILIO_ACCOUNT_SID=ACxxx
# TWILIO_AUTH_TOKEN=xxx
# TWILIO_PHONE_NUMBER=+14155551234

# ==========================================
# OpenAI (Opcional — solo para ejecución real de AI agents)
# ==========================================
# OPENAI_API_KEY=sk-...

# ==========================================
# Google Workspace (Opcional — solo para integración real con Drive/Calendar)
# ==========================================
# GOOGLE_CLIENT_ID=...
# GOOGLE_CLIENT_SECRET=...
