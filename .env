# YOUR ERP - Archivo de configuración de entorno
# ================================================

# AMBIENTE DE EJECUCIÓN
ENVIRONMENT=development

# SERVIDOR
HOST=0.0.0.0
PORT=8000

# BASE DE DATOS (SQLite para desarrollo local)
DATABASE_TYPE=sqlite
DATABASE_NAME=./erp_dev.db

# SEGURIDAD
SECRET_KEY=dev-secret-key-12345-change-in-production

# EMAIL (SMTP)
EMAIL_BACKEND=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=your-app-password
SMTP_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@yourerp.com

# LOGGING
LOG_LEVEL=DEBUG

# MÓDULOS A CARGAR
MODULES_TO_LOAD=base,signature

# REDIS (Caché y colas)
REDIS_URL=redis://localhost:6379/0

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost:5000
