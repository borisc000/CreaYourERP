rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isAuthenticated() {
      return request.auth != null;
    }

    function getCompanyId() {
      return request.auth.token.companyId;
    }

    function belongsToCompany(companyId) {
      return isAuthenticated() && getCompanyId() == companyId;
    }

    // Documentos por empresa: /companies/{companyId}/documents/...
    // /companies/{companyId}/signatures/...
    // /companies/{companyId}/safety/...
    match /companies/{companyId}/{allPaths=**} {
      allow read: if belongsToCompany(companyId);
      allow write: if belongsToCompany(companyId)
        && request.resource.size < 20 * 1024 * 1024  // max 20 MB
        && request.resource.contentType.matches('application/pdf|image/.*|application/vnd.openxmlformats-officedocument.*|text/.*');
    }

    // Bloquear todo lo demás
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
