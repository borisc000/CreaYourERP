import { useState } from 'react';
import { useNavigate } from 'react-router-dom';
import { useFirestoreCollection } from '@/hooks/useFirestore';
import { {{NameCapitalized}} } from '@/types/{{name}}';

export function {{NameCapitalized}}List() {
  const navigate = useNavigate();
  const { data, loading } = useFirestoreCollection<{{NameCapitalized}}>('{{collectionName}}');
  const [search, setSearch] = useState('');

  const filtered = data.filter((item) =>
    item.name.toLowerCase().includes(search.toLowerCase())
  );

  if (loading) return <div>Cargando...</div>;

  return (
    <div className="space-y-4">
      <div className="flex justify-between items-center">
        <h1 className="text-2xl font-bold">{{NameCapitalized}}</h1>
        <button
          onClick={() => navigate('/{{name}}/new')}
          className="btn btn-primary"
        >
          Nuevo {{NameCapitalized}}
        </button>
      </div>

      <input
        type="text"
        placeholder="Buscar..."
        value={search}
        onChange={(e) => setSearch(e.target.value)}
        className="input input-bordered w-full max-w-sm"
      />

      <div className="grid gap-4">
        {filtered.map((item) => (
          <div
            key={item.id}
            onClick={() => navigate(`/{{name}}/${item.id}`)}
            className="card bg-base-100 shadow-sm cursor-pointer hover:shadow-md transition"
          >
            <div className="card-body p-4">
              <h3 className="card-title text-lg">{item.name}</h3>
              <p className="text-sm text-base-content/60">{item.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  );
}
